# OpenAI-compatible LLM endpoint. Leave OFFLINE=1 for deterministic local checks.
OFFLINE=1

# Public OpenAI fallback:
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini

# Course/self-hosted endpoint:
# LLM_BASE_URL=https://api.deepseek.com
# LLM_AUTH_TOKEN=your_token_here
# LLM_MODEL=deepseek-v4-flash

# Optional throttling for free-tier providers.
LLM_CALL_INTERVAL_SEC=0
LLM_TIMEOUT=120
